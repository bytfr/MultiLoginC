# MultiLogin 版本配置文件
# 修改此文件即可统一控制项目版本号，无需修改其他地方
#
# 正式版版本号（发布时使用）
# 格式：主版本.次版本.修订号 或 自定义字符串（如 a260408）
# 当 build.gradle 中 env=final 时生效
RELEASE_VERSION=1.0.0

# 构建类型: AUTO (自动=Build_{gitCommitId}) / FINAL (使用上面的 RELEASE_VERSION)
BUILD_ENV=AUTO

# 最新版本列表（用于更新检查，每行一个版本号）
# 发布正式版时，将新版本号添加到此列表
# 构建时会自动同步到 latest 文件
LATEST_VERSIONS=1.0.0
